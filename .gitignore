# Dependencies
**/node_modules/
**/.pnp
**/.pnp.js

# Build output
backend/dist/
frontend/dist/
pi-build/

# --- LIVE DATA: never commit these ---
# SQLite database (your actual orders/products data)
backend/prisma/*.db
backend/prisma/*.db-journal
**/*.db
**/*.db-journal
# SQLite WAL/shared-memory sidecars + manual .bak copies
**/*.db-shm
**/*.db-wal
**/*.db.bak-*
# Uploaded product images
backend/uploads/*
!backend/uploads/.gitkeep

# Env / secrets (per-host config — copy .env.example to .env locally)
**/.env
.env
.env.*
!.env.example

# Logs
**/*.log
npm-debug.log*

# OS / editor cruft
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
# Windows reserved-name artifacts (accidental `> nul` redirects)
nul
